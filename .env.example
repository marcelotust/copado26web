# Supabase project credentials.
# Copy this file to `.env.local` and fill in the values from
# https://app.supabase.com → Project Settings → API.
#
# Both variables are exposed to the browser bundle — the anon key is meant to
# be public. Security is enforced by row-level security policies on the
# `user_stickers` table; do NOT commit a service_role key here or anywhere
# else in this repo.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
