{
  "enabledPlugins": {
    "vercel@claude-plugins-official": true
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "scripts/ai-hooks/adapters/stdin-shell-guard.sh" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          { "type": "command", "command": "scripts/ai-hooks/adapters/post-edit-harness.sh" }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          { "type": "command", "command": "scripts/ai-hooks/adapters/stop-harness.sh" }
        ]
      }
    ]
  }
}
