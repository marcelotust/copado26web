{
  "name": "meualbum2026",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.15.0",
    "npm": ">=11"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:ci": "vitest run --reporter=verbose",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:public": "playwright test --project=public",
    "test:e2e:auth": "playwright test --project=setup --project=authenticated",
    "test:coverage": "vitest run --coverage",
    "ai:harness": "node scripts/ai-harness.mjs",
    "ai:harness:test": "node --test scripts/ai-harness.personas.test.mjs",
    "sentry:triage": "node scripts/sentry-triage.mjs",
    "posthog:metrics-check": "node scripts/posthog-metrics-check.mjs",
    "posthog:llm-ingest": "node scripts/posthog-llm-ingest.mjs",
    "posthog:llm-status": "node scripts/posthog-llm-ingest.mjs --status",
    "posthog:llm-check-env": "node scripts/posthog-llm-ingest.mjs --check-env",
    "supabase:sync-email-templates": "node scripts/sync-auth-email-templates.mjs",
    "supabase:sync-email-templates:check-env": "node scripts/sync-auth-email-templates.mjs --check-env",
    "supabase:sync-email-templates:test": "node --test scripts/sync-auth-email-templates.test.mjs",
    "brand:export": "node scripts/export-brand-pack.mjs",
    "prepare": "husky"
  },
  "dependencies": {
    "@sentry/react": "^10.53.1",
    "@supabase/supabase-js": "^2.105.4",
    "@vercel/analytics": "^2.0.1",
    "lz-string": "^1.5.0",
    "posthog-js": "^1.373.4",
    "qrcode.react": "^4.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.14.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@fontsource/bebas-neue": "^5.2.7",
    "@playwright/test": "^1.60.0",
    "@sentry/vite-plugin": "^4.9.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/lz-string": "^1.3.34",
    "@types/node": "^20.19.41",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.4.19",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^15.15.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.4",
    "opentype.js": "^2.0.0",
    "postcss": "^8.4.38",
    "qrcode": "^1.5.4",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.3",
    "vite": "^8.0.13",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.6"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --fix",
      "bash -c 'tsc --noEmit'"
    ]
  }
}
