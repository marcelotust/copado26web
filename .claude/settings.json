{
  "permissions": {
    "allow": [
      "Bash(npx tsc *)",
      "mcp__plugin_chrome-devtools-mcp_chrome-devtools__list_console_messages",
      "Bash(gh pr *)",
      "Bash(npx eslint *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "scripts/ai-hooks/adapters/stdin-shell-guard.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "scripts/ai-hooks/adapters/post-edit-harness.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "scripts/ai-hooks/adapters/stop-harness.sh"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "vercel@claude-plugins-official": true
  }
}
