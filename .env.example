# Supabase project credentials.
# Copy this file to `.env.local` and fill in the values from
# https://app.supabase.com → Project Settings → API.
#
# Both variables are exposed to the browser bundle — the anon key is meant to
# be public. Security is enforced by row-level security policies on the
# `user_stickers` table; do NOT commit a service_role key here or anywhere
# else in this repo.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional: canonical public URL for share links (WhatsApp, clipboard). If unset,
# the app uses window.location.origin (fine for most deployments).
# VITE_APP_URL=https://your-domain.com

# Optional: Sentry error monitoring (https://sentry.io → Project Settings → Client Keys).
# Client capture is disabled in `npm run dev` and only runs after analytics consent (LGPD).
# VITE_SENTRY_DSN=https://your-dsn@oXXX.ingest.sentry.io/XXX
# VITE_SENTRY_RELEASE=meualbum2026@1.0.0

# Optional: PostHog product analytics & feature flags (https://posthog.com → Project Settings).
# Disabled in `npm run dev` (same as Sentry); only loads after analytics consent. See docs/setup-sentry-posthog.md.
# VITE_POSTHOG_KEY=phc_...
# VITE_POSTHOG_HOST=https://us.i.posthog.com

# Claude Code LLM Analytics (local CLI only — see docs/claude-code-llm-analytics.md):
# POSTHOG_LLMA_CC_ENABLED=true
# POSTHOG_API_KEY=phc_...   # same project key as VITE_POSTHOG_KEY
# POSTHOG_HOST=https://us.i.posthog.com
# POSTHOG_LLMA_PRIVACY_MODE=true

# Vercel build — upload source maps (Settings → Environment Variables, Build only):
# SENTRY_AUTH_TOKEN=sntrys_...
# SENTRY_ORG=your-org-slug
# SENTRY_PROJECT=meualbum2026
# VERCEL_GIT_COMMIT_SHA is set automatically on Vercel and used as release id.

# E2E / CI only (not read by Vite — export in shell or set in GitHub Actions):
# E2E_TEST_EMAIL=
# E2E_TEST_PASSWORD=
# E2E_SUPABASE_SERVICE_ROLE_KEY=
