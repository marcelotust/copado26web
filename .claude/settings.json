{
  "permissions": {
    "allow": [
      "Bash(npx tsc *)",
      "mcp__plugin_chrome-devtools-mcp_chrome-devtools__list_console_messages",
      "Bash(gh pr *)",
      "Bash(npx eslint *)",
      "Bash(gh issue create --title 'feat\\(loading\\): ball squish effect + BrandMark logo on loading screen' --body ' *)",
      "Bash(gh issue create --title 'feat: move sticker +/- buttons below card in album grid' --body ' *)",
      "Bash(ls /Users/marcelotust/Projetos/copado26web/docs/superpowers/plans/ 2>/dev/null || mkdir -p /Users/marcelotust/Projetos/copado26web/docs/superpowers/plans/)"
    ],
    "additionalDirectories": [
      "/Users/marcelotust/Projetos/copado26web/docs/superpowers/plans"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "scripts/ai-hooks/adapters/stdin-shell-guard.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "scripts/ai-hooks/adapters/post-edit-harness.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "scripts/ai-hooks/adapters/stop-harness.sh"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "vercel@claude-plugins-official": true
  }
}
